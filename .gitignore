# env
.venv/
.env
.env.local

# python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.hypothesis/
*.egg-info/

# numba AOT cache (machine-specific LLVM-codegen artifacts; safe under
# the __pycache__/ rule above but listed explicitly per R-7 audit
# defense-in-depth in case a future env sets NUMBA_CACHE_DIR elsewhere).
*.nbi
*.nbc
**/numba_cache/

# data (raw/interim/processed parquets are binary + regenerable;
# _provenance/** is tracked as the audit-record surface. DVC is the
# longer-term plan for processed artifacts if adopted.)
data/raw/**
data/interim/**
data/external/**
data/processed/**
!data/processed/_provenance
!data/processed/_provenance/**
!data/**/.gitkeep

# notebooks stripped
*-checkpoint.ipynb

# artifacts
artifacts/models/**
!artifacts/models/.gitkeep
logs/**
!logs/**/.gitkeep
# Load-bearing audit evidence: keep crash-evidence dumps versioned
# (R-1 from ADR-0010 Round-1 audit + R-1-RESIDUAL from Round-2).
# These are one-time captures from Windows event logs; the original
# event-log entries roll out over time. NOTE: per git-scm.com/docs/gitignore
# we must un-ignore the directory itself BEFORE its contents — git
# refuses to re-include children of an excluded parent directory.
!logs/crash_evidence/
!logs/crash_evidence/**

# NinjaTrader build output
ninjascript/**/bin/
ninjascript/**/obj/

# os
.DS_Store
Thumbs.db

# claude-code local harness state (session locks, per-machine config)
.claude/
