# env
.venv/
.env
.env.local

# python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.hypothesis/
*.egg-info/

# numba AOT cache (machine-specific LLVM-codegen artifacts; safe under
# the __pycache__/ rule above but listed explicitly per R-7 audit
# defense-in-depth in case a future env sets NUMBA_CACHE_DIR elsewhere).
*.nbi
*.nbc
**/numba_cache/

# data (raw/interim/processed parquets are binary + regenerable;
# _provenance/** is tracked as the audit-record surface. DVC is the
# longer-term plan for processed artifacts if adopted.)
data/raw/**
data/interim/**
data/external/**
data/processed/**
!data/processed/_provenance
!data/processed/_provenance/**
!data/**/.gitkeep
# H055 pilot ledger: small NinjaTrader CSV (~14 KB) + dataset card; tracked
# as load-bearing pre-registration artifact per research/01_hypothesis_register/H055/data_requirements.md
!data/external/h055_pilot_ledger/
!data/external/h055_pilot_ledger/**

# notebooks stripped
*-checkpoint.ipynb

# artifacts
artifacts/models/**
!artifacts/models/.gitkeep
logs/**
!logs/**/.gitkeep
# Load-bearing audit evidence: keep crash-evidence dumps versioned
# (R-1 from ADR-0010 Round-1 audit + R-1-RESIDUAL from Round-2).
# These are one-time captures from Windows event logs; the original
# event-log entries roll out over time. NOTE: per git-scm.com/docs/gitignore
# we must un-ignore the directory itself BEFORE its contents — git
# refuses to re-include children of an excluded parent directory.
!logs/crash_evidence/
!logs/crash_evidence/**
# ADR-0013 §5.3 + §6 promotion logs: append-only operator-decision record;
# protected by the §4.3 non-loss-guard. Same un-ignore pattern as
# crash_evidence: directory first, then contents.
!logs/promotions/
!logs/promotions/**
# ADR-0013 §4.1 #4 ReproLogs: every run record retained; protected by the
# §4.3 non-loss-guard. Per Round-2 audit R-2-16: without this exception the
# protected-path was structurally unenforceable (gitignore'd files cannot
# be tracked, and the guard only detects deletion of tracked files).
!logs/reproducibility/
!logs/reproducibility/**
# Databento cost dossiers: binding T_live records per ADR-0023 §Decision 6 +
# H050 Cell-I precedent. Append-only operator-spend audit trail; api_key_fingerprint
# is suppressed in script output by defense-in-depth hardening per the 2026-05-12
# chat-transcript-exposure event (no key material persists to these files).
!logs/databento_cost_dossiers/
!logs/databento_cost_dossiers/**

# NinjaTrader build output
ninjascript/**/bin/
ninjascript/**/obj/

# os
.DS_Store
Thumbs.db

# claude-code local harness state (session locks, per-machine config)
.claude/
